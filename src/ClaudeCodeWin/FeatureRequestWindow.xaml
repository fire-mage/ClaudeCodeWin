<Window x:Class="ClaudeCodeWin.FeatureRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Feature Request"
        Width="500" Height="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Submit a Feature Request"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryBrush}"/>

        <!-- Email -->
        <TextBlock Grid.Row="1" Text="Email" Margin="0,16,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
        <TextBox x:Name="EmailBox" Grid.Row="2"
                 Padding="8,6" FontSize="13"
                 Background="{DynamicResource SurfaceBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"/>

        <!-- Description -->
        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Top" Text="Describe the feature you'd like" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
            <TextBox x:Name="DescriptionBox"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="8,6" FontSize="13"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"/>
        </DockPanel>

        <!-- Info text -->
        <TextBlock Grid.Row="4" Margin="0,12,0,0" TextWrapping="Wrap" FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}">
            Your requests help shape CCW's future. For personalized features,
            ask for an activation code via GitHub Issues.
        </TextBlock>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="5" Margin="0,8,0,0"
                   FontSize="12" TextWrapping="Wrap"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="24,8" Margin="0,0,8,0"
                    Background="Transparent"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Cursor="Hand"
                    Click="Cancel_Click"/>
            <Button x:Name="SendButton" Content="Send" Padding="24,8"
                    Style="{StaticResource PrimaryButton}" Cursor="Hand"
                    Click="Send_Click"/>
        </StackPanel>
    </Grid>
</Window>
