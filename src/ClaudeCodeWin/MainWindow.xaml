<Window x:Class="ClaudeCodeWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ClaudeCodeWin.Converters"
        xmlns:vm="clr-namespace:ClaudeCodeWin.ViewModels"
        xmlns:models="clr-namespace:ClaudeCodeWin.Models"
        xmlns:views="clr-namespace:ClaudeCodeWin.Views"
        Title="Claude Code for Windows (CCW)"
        MinHeight="500" MinWidth="600"
        Background="{StaticResource BackgroundBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:RoleToAlignmentConverter x:Key="RoleToAlign"/>
        <converters:RoleToBubbleBrushConverter x:Key="RoleToBubble"/>
        <converters:RoleToMaxWidthConverter x:Key="RoleToMaxWidth"/>
        <converters:EditDiffLineTypeToBrushConverter x:Key="DiffLineBrush"/>
        <converters:GitStatusToBrushConverter x:Key="GitStatusBrush"/>
        <converters:StatusTextToBrushConverter x:Key="StatusTextBrush"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>

        <!-- Compact inline checkbox style used in the toolbar area -->
        <Style x:Key="InlineCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBorder" Width="14" Height="14" CornerRadius="2"
                                    BorderBrush="{StaticResource TextSecondaryBrush}"
                                    BorderThickness="1"
                                    Background="Transparent"
                                    VerticalAlignment="Center" Margin="0,0,5,0">
                                <TextBlock x:Name="Check" Text="&#x2713;" FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.TaskbarItemInfo>
        <TaskbarItemInfo/>
    </Window.TaskbarItemInfo>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Menu -->
            <RowDefinition Height="*"/>        <!-- Main body: vertical tabs + content -->
            <RowDefinition Height="Auto"/>     <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Menu bar with gradient border -->
        <StackPanel Grid.Row="0">
            <Menu Background="{StaticResource SurfaceBrush}">
                <MenuItem Header="S_cripts" x:Name="ScriptsMenu" Visibility="Collapsed"/>
                <MenuItem Header="My _Scripts" x:Name="TasksMenu"
                          ToolTip="Shell commands: run predefined terminal commands in your project folder.&#x0a;Output appears in a separate window. Customize via tasks.json.&#x0a;Example: 'Git Status' runs 'git status' and displays the result."/>
                <MenuItem Header="_Claude"
                          ToolTip="Ask Claude to learn new skills or view what Claude already knows">
                    <MenuItem Header="_Marketplace..." Click="MenuItem_Marketplace_Click"
                              ToolTip="Browse and install skills and plugins for Claude."/>
                    <MenuItem Header="Explore _Skill..." Click="MenuItem_ExploreSkill_Click"
                              ToolTip="Provide a skill, article, or URL for Claude to study and add to its Knowledge Base."/>
                    <MenuItem Header="_Knowledge Base..." Click="MenuItem_KnowledgeBase_Click"
                              ToolTip="View the articles Claude has saved in its personal Knowledge Base for this project."/>
                    <Separator/>
                    <MenuItem Header="Full Project _Review..." Click="MenuItem_FullProjectReview_Click"
                              ToolTip="Launch a comprehensive module-by-module code review of the entire project.&#x0a;Runs in the background via the Team pipeline. Ideal for overnight runs."/>
                </MenuItem>
                <MenuItem Header="_App"
                          ToolTip="Project management, updates, and application information">
                    <MenuItem Header="Check for _Updates..." Command="{Binding Update.CheckForUpdatesCommand}"
                              ToolTip="Check if a newer version is available on the update server.&#x0a;If found, download and install with one click. Also checks automatically every 4 hours."/>
                    <MenuItem Header="Check for CLI Updates..." Command="{Binding Update.CheckCliUpdatesCommand}"
                              ToolTip="Check if a newer version of Claude Code CLI is available.&#x0a;CLI is the backend engine that powers this application."/>
                    <MenuItem Header="_Settings..." Click="MenuItem_Settings_Click"
                              ToolTip="Application settings: update channel, preferences."/>
                    <Separator/>
                    <MenuItem Header="_Feature Request..." Click="MenuItem_FeatureRequest_Click"
                              ToolTip="Submit a feature request or enhancement idea for CCW."/>
                    <MenuItem Header="_About" Click="MenuItem_About_Click"
                              ToolTip="Application version, build date, and support contacts."/>
                </MenuItem>
            </Menu>
            <!-- Gradient accent stripe (green → orange → yellow) -->
            <Border Height="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4CAF50" Offset="0"/>
                        <GradientStop Color="#FFAB1A" Offset="0.6"/>
                        <GradientStop Color="#F9A825" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </StackPanel>

        <!-- Main body: vertical project tabs (left) + content area (right) -->
        <Grid Grid.Row="1" x:Name="MainBodyGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" x:Name="ProjectTabColumn"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: vertical project tabs -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Bottom: compact/expand toggle -->
                    <Button DockPanel.Dock="Bottom"
                            FontSize="12" Padding="6,6" Margin="2,2"
                            Command="{Binding ToggleTabPanelCompactCommand}"
                            ToolTip="Toggle compact panel"
                            Style="{StaticResource TabAddButton}">
                        <Button.Content>
                            <Grid>
                                <TextBlock Text="«" FontSize="14"
                                           Visibility="{Binding IsTabPanelFull, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="»" FontSize="14"
                                           Visibility="{Binding IsTabPanelCompact, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button.Content>
                    </Button>

                    <!-- Top: Open Project button -->
                    <Button x:Name="OpenProjectButton"
                            DockPanel.Dock="Top"
                            Click="OpenProjectTab_Click"
                            Padding="10,8" Margin="4,4"
                            ToolTip="Open a project in a new tab (Ctrl+T)"
                            Style="{StaticResource TabAddButton}">
                        <Button.Content>
                            <Grid>
                                <TextBlock Text="Open Project" FontSize="12"
                                           Visibility="{Binding IsTabPanelFull, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                           Visibility="{Binding IsTabPanelCompact, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button.Content>
                    </Button>

                    <!-- Tab list -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:MainViewModel}">
                                <Border x:Name="VTabBorder" Padding="10,8" Margin="2,2,2,0"
                                        CornerRadius="4" Cursor="Hand"
                                        Background="{StaticResource SurfaceBrush}"
                                        MouseLeftButtonUp="TabHeader_Click" Tag="{Binding}">
                                    <Grid>
                                        <!-- Full mode: horizontal layout -->
                                        <Grid x:Name="FullModeLayout"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding DataContext.IsTabPanelFull,
                                                           RelativeSource={RelativeSource AncestorType=Window},
                                                           Converter={StaticResource BoolToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                        Margin="0,0,6,0" VerticalAlignment="Center">
                                                <Ellipse Width="6" Height="6" Margin="0,0,3,0"
                                                         Fill="{StaticResource PrimaryBrush}"
                                                         Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"/>
                                                <Ellipse Width="6" Height="6"
                                                         Fill="{StaticResource SuccessBrush}"
                                                         Visibility="{Binding HasNotification, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding TabTitle}" FontSize="12"
                                                       Foreground="{StaticResource TextBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border Grid.Column="2" Padding="6,0,0,0" Cursor="Hand"
                                                    Background="Transparent"
                                                    MouseLeftButtonUp="TabClose_Click" Tag="{Binding}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="x" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </Border>
                                        </Grid>

                                        <!-- Compact mode: rotated vertical text.
                                             Uses Grid (not StackPanel) for row layout.
                                             MaxWidth on the TextBlock provides a finite width constraint
                                             that after -90° rotation becomes the visual height cap. -->
                                        <Grid x:Name="CompactModeLayout"
                                              MaxHeight="200"
                                              Visibility="{Binding DataContext.IsTabPanelCompact,
                                                           RelativeSource={RelativeSource AncestorType=Window},
                                                           Converter={StaticResource BoolToVis}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <!-- Close button -->
                                            <Border Grid.Row="0" Padding="4,2" Cursor="Hand"
                                                    Background="Transparent" HorizontalAlignment="Center"
                                                    MouseLeftButtonUp="TabClose_Click" Tag="{Binding}">
                                                <TextBlock Text="x" FontSize="9"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                            <!-- Status dots -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"
                                                        Margin="0,0,0,4">
                                                <Ellipse Width="5" Height="5" Margin="0,0,2,0"
                                                         Fill="{StaticResource PrimaryBrush}"
                                                         Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"/>
                                                <Ellipse Width="5" Height="5"
                                                         Fill="{StaticResource SuccessBrush}"
                                                         Visibility="{Binding HasNotification, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                            <!-- Rotated title — Auto row + MaxWidth caps long names;
                                                 after -90° rotation MaxWidth limits the visual tab height -->
                                            <TextBlock Grid.Row="2" Text="{Binding TabTitle}" FontSize="11"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MinWidth="40"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center">
                                                <TextBlock.LayoutTransform>
                                                    <RotateTransform Angle="-90"/>
                                                </TextBlock.LayoutTransform>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsActiveTab}" Value="True">
                                        <Setter TargetName="VTabBorder" Property="Background"
                                                Value="{StaticResource SurfaceLightBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.IsTabPanelCompact,
                                                           RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        <Setter TargetName="VTabBorder" Property="Padding" Value="4,4"/>
                                        <Setter TargetName="VTabBorder" Property="Margin" Value="1,1,1,0"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- GridSplitter between left panel and content -->
            <GridSplitter x:Name="MainBodyGridSplitter"
                          Grid.Column="1" Width="4" ResizeDirection="Columns"
                          HorizontalAlignment="Stretch" Cursor="SizeWE"
                          Style="{StaticResource ProjectPanelSplitter}"/>

            <!-- Content area — bound to the active tab's ViewModel -->
            <Grid Grid.Column="2" DataContext="{Binding ActiveTab}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>     <!-- Inner sub-tab strip -->
                    <RowDefinition Height="*"/>        <!-- Content (Explorer / Chat / File editor) -->
                </Grid.RowDefinitions>

                <!-- Inner sub-tab strip: Explorer | Chat | file tabs -->
                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <ItemsControl ItemsSource="{Binding SubTabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SubTab}">
                                <Border x:Name="SubTabBorder" Padding="10,5" Margin="0,0,1,0"
                                        CornerRadius="4,4,0,0" Cursor="Hand"
                                        Background="{StaticResource SurfaceBrush}"
                                        MouseLeftButtonUp="SubTab_Click" Tag="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayTitle}" FontSize="12"
                                                   Foreground="{StaticResource TextBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="180"/>
                                        <!-- Close button for file tabs -->
                                        <Border Padding="6,0,0,0" Cursor="Hand"
                                                Background="Transparent"
                                                MouseLeftButtonUp="SubTabClose_Click" Tag="{Binding}"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsCloseable, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="x" FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                        <!-- Badge count (e.g. awaiting user input on Team tab) -->
                                        <Border Padding="4,1" Margin="4,0,0,0"
                                                CornerRadius="8" MinWidth="16"
                                                Background="{StaticResource AccentBrush}"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding BadgeCount, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding BadgeCount}" FontSize="9"
                                                       Foreground="#0d1117" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter TargetName="SubTabBorder" Property="Background"
                                                Value="{StaticResource SurfaceLightBrush}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- === Content area: Explorer / Chat / File Editor / Team === -->
                <Grid Grid.Row="1">

                    <!-- Explorer panel -->
                    <Border Visibility="{Binding IsExplorerActive, Converter={StaticResource BoolToVis}}">
                        <views:FileExplorerControl DataContext="{Binding Explorer}"/>
                    </Border>

                    <!-- Notepad panel -->
                    <Border Visibility="{Binding IsNotepadActive, Converter={StaticResource BoolToVis}}">
                        <views:NotepadControl DataContext="{Binding Notepad}"/>
                    </Border>

                    <!-- File editor panel -->
                    <Grid Visibility="{Binding IsFileEditorActive, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Editor toolbar -->
                            <RowDefinition Height="*"/>     <!-- Editor -->
                        </Grid.RowDefinitions>

                        <!-- Editor toolbar -->
                        <Border Grid.Row="0" Padding="8,4"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Save" Padding="8,3" Margin="0,0,4,0"
                                        Style="{StaticResource SubTabToolButton}"
                                        Command="{Binding SaveFileCommand}"
                                        ToolTip="Save file (Ctrl+S)"/>
                                <Button Content="Send to Review" Padding="8,3"
                                        Style="{StaticResource SubTabToolButton}"
                                        Command="{Binding SendFileToReviewCommand}"
                                        ToolTip="Send this file to Claude for review"/>
                            </StackPanel>
                        </Border>

                        <!-- Code editor with line numbers, search/replace -->
                        <views:CodeEditorControl Grid.Row="1"
                                                 x:Name="FileEditor"
                                                 Text="{Binding ActiveFileTab.Content, UpdateSourceTrigger=PropertyChanged}"
                                                 FilePath="{Binding ActiveFileTab.FilePath}"/>
                    </Grid>

                    <!-- Chat panel (existing chat UI) -->
                    <Grid Visibility="{Binding IsChatActive, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>        <!-- Chat -->
                            <RowDefinition Height="Auto"/>     <!-- Message queue -->
                            <RowDefinition Height="Auto"/>     <!-- Attachments -->
                            <RowDefinition Height="Auto"/>     <!-- CTA hint -->
                            <RowDefinition Height="Auto"/>     <!-- Use Reviewer toggle -->
                            <RowDefinition Height="Auto"/>     <!-- Input -->
                            <RowDefinition Height="Auto"/>     <!-- Background tasks -->
                            <RowDefinition Height="Auto"/>     <!-- Changed files -->
                        </Grid.RowDefinitions>

                <views:ChatControl x:Name="ChatDisplay"
                                   Grid.Row="0"
                                   Messages="{Binding Messages}"
                                   CommandSource="{Binding}"/>

                <!-- Overlay banners — StackPanel auto-stacks, no hardcoded offsets -->
                <StackPanel Grid.Row="0"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Stretch"
                            Panel.ZIndex="15">
                    <!-- Rate limit banner -->
                    <Border Visibility="{Binding ShowRateLimitBanner, Converter={StaticResource BoolToVis}}">
                        <Border Background="#CC45475a"
                                BorderBrush="{StaticResource WarningBrush}"
                                BorderThickness="0,0,0,2"
                                Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#x23F3; " FontSize="16"
                                           Foreground="{StaticResource WarningBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}">
                                        <Run Text="Rate limit reached. Resets in "/>
                                        <Run Text="{Binding RateLimitCountdown, Mode=OneWay}"
                                             Foreground="{StaticResource WarningBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Your session will auto-resume when ready."
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="Upgrade Account"
                                        Margin="12,0,0,0" Padding="12,4"
                                        Cursor="Hand"
                                        Command="{Binding UpgradeAccountCommand}"
                                        ToolTip="Open Anthropic billing page in browser">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background"
                                                                        Value="{StaticResource PrimaryBrush}"/>
                                                                <Setter Property="Foreground"
                                                                        Value="{StaticResource BackgroundBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Grid.Column="3" Content="&#x2715;"
                                        Margin="8,0,0,0" Padding="6,2"
                                        Cursor="Hand"
                                        Command="{Binding DismissRateLimitCommand}"
                                        ToolTip="Dismiss">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- Conflict pause banner -->
                    <Border Visibility="{Binding IsConflictBannerVisible, Converter={StaticResource BoolToVis}}">
                        <Border Background="#CC45475a"
                                BorderBrush="{StaticResource WarningBrush}"
                                BorderThickness="0,0,0,2"
                                Padding="16,8">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="Edit anyway"
                                            Command="{Binding EditAnywayCommand}"
                                            IsEnabled="{Binding IsConflictActionable}"
                                            Style="{StaticResource SmallButtonStyle}"
                                            Margin="8,0,4,0"
                                            ToolTip="Approve this edit without waiting for team to pause"/>
                                    <Button Content="Cancel"
                                            Command="{Binding CancelConflictCommand}"
                                            IsEnabled="{Binding IsConflictActionable}"
                                            Style="{StaticResource SmallButtonStyle}"
                                            ToolTip="Deny this edit and stop the current session"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#x26A0; " FontSize="14"
                                               Foreground="{StaticResource WarningBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ConflictBannerText}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource WarningBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </Border>
                </StackPanel>

                <!-- Bookmarks button -->
                <Border x:Name="BookmarksButton"
                        Grid.Row="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,24,48"
                        Panel.ZIndex="5"
                        Visibility="Collapsed"
                        Cursor="Hand"
                        MouseLeftButtonUp="BookmarksButton_Click"
                        ToolTip="Jump to bookmarked messages">
                    <Border Background="{StaticResource SurfaceLightBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="10,6">
                        <TextBlock Text="&#x2605; Bookmarks" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </Border>
                    <Border.ContextMenu>
                        <ContextMenu x:Name="BookmarksContextMenu"
                                     Background="{StaticResource SurfaceBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     Foreground="{StaticResource TextBrush}"/>
                    </Border.ContextMenu>
                </Border>

                <!-- Finalize Actions popup -->
                <Border x:Name="FinalizePopupBorder"
                        Grid.Row="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,24,12"
                        Panel.ZIndex="15"
                        Visibility="{Binding FinalizeActions.ShowTaskSuggestion, Converter={StaticResource BoolToVis}}"
                        MaxWidth="320"
                        RenderTransformOrigin="1,1">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,12">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="16" ShadowDepth="4"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Header with timer and close button -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="&#x26A1; Finalize Actions"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FinalizeActions.FinalizeCountdown, StringFormat={}{0}s}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,4,0"/>
                                <Button Grid.Column="2"
                                        Content="&#x2715;"
                                        Command="{Binding FinalizeActions.CloseFinalizePopupCommand}"
                                        Background="Transparent"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        BorderThickness="0"
                                        FontSize="14"
                                        Cursor="Hand"
                                        Padding="4,0"
                                        ToolTip="Collapse"/>
                            </Grid>
                            <TextBlock Text="{Binding FinalizeActions.ProjectName}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>

                            <!-- Dynamic action buttons -->
                            <ItemsControl ItemsSource="{Binding FinalizeActions.SuggestedTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.ActiveTab.FinalizeActions.RunSuggestedTaskCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,0,0,4"
                                                Padding="12,7"
                                                FontSize="12.5"
                                                IsEnabled="{Binding IsCompleted, Converter={StaticResource InverseBool}}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Content>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding Label}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                    <Setter Property="Text" Value="{Binding CompletedStatusText}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button.Content>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Small "Don't suggest" link -->
                            <Border Cursor="Hand" Background="Transparent"
                                    HorizontalAlignment="Right" Margin="0,6,0,0">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding FinalizeActions.DontSuggestForProjectCommand}"/>
                                </Border.InputBindings>
                                <TextBlock Text="Don't suggest for this project"
                                           FontSize="10.5"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextDecorations="Underline"
                                           ToolTip="Stop showing finalize actions for this project"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Welcome overlay (covers full content area incl. inner tab strip) -->
                <Border Grid.Row="0" Grid.RowSpan="2"
                        Background="{StaticResource BackgroundBrush}"
                        Visibility="{Binding ShowWelcome, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="50">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel MaxWidth="560" Margin="28,40,28,28"
                                    HorizontalAlignment="Center">

                            <!-- ===== First-time content ===== -->
                            <StackPanel x:Name="FirstTimePanel">
                                <TextBlock Text="Welcome to ClaudeCodeWin!"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>
                                <TextBlock Text="Select a project folder to get started."
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,24"/>

                                <Button Content="Browse..."
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding SelectFolderCommand}"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,24"
                                        Padding="32,10"/>

                                <!-- Recent folders -->
                                <TextBlock Text="Recent Projects"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,8"
                                           Visibility="{Binding RecentFolders.Count, Converter={StaticResource BoolToVis}}"/>

                                <ItemsControl ItemsSource="{Binding RecentFolders}"
                                              Visibility="{Binding RecentFolders.Count, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceBrush}"
                                                    CornerRadius="6" Padding="12,8" Margin="0,0,0,4"
                                                    Cursor="Hand">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextBrush}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource ChipCloseButton}"
                                                            Command="{Binding DataContext.ActiveTab.RemoveRecentFolderCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="8,0,0,0"/>
                                                </Grid>

                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftClick"
                                                                  Command="{Binding DataContext.ActiveTab.OpenRecentFolderCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>

                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- ===== Returning user content ===== -->
                            <StackPanel x:Name="ReturningPanel" Visibility="Collapsed">

                                <!-- Title -->
                                <TextBlock Text="Welcome back!"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Margin="0,0,0,20"/>

                                <!-- Section 1: New Chat (recommended) -->
                                <Border x:Name="WbNewChatOption"
                                        Background="{StaticResource SurfaceBrush}"
                                        CornerRadius="6" Padding="14,12" Margin="0,0,0,16"
                                        Cursor="Hand"
                                        BorderThickness="2"
                                        BorderBrush="{StaticResource PrimaryBrush}"
                                        MouseLeftButtonUp="WbNewChat_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="+" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="New Chat" FontSize="15" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}"/>
                                                <Border Background="{StaticResource PrimaryDarkBrush}"
                                                        CornerRadius="3" Padding="6,1" Margin="10,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="Recommended" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="#FFFFFF"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock x:Name="WbNewChatSubtitle"
                                                       Text="Start a fresh conversation"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!-- Section 3: Continue Previous Chat -->
                                <Border x:Name="WbContinueChatSection"
                                        Background="{StaticResource SurfaceBrush}"
                                        CornerRadius="6" Padding="14,12" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Continue Previous Chat"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,0,0,10"/>

                                        <ListView x:Name="WbRecentChatsList"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Foreground="{StaticResource TextBrush}"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  SelectionChanged="WbRecentChats_SelectionChanged"
                                                  MouseDoubleClick="WbRecentChats_DoubleClick">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0,0,0,4"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListViewItem">
                                                                <Border x:Name="Bd" Background="{StaticResource BackgroundBrush}"
                                                                        Padding="12,8" CornerRadius="6"
                                                                        BorderThickness="2" BorderBrush="Transparent"
                                                                        Cursor="Hand">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="Bd" Property="BorderBrush"
                                                                                Value="{StaticResource PrimaryBrush}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background"
                                                                                Value="{StaticResource SurfaceLightBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Text="{Binding Title}"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                                   Text="{Binding UpdatedAt, StringFormat='{}{0:MMM dd, HH:mm}'}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,0,0"/>

                                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                                    Orientation="Horizontal" Margin="0,3,0,0">
                                                            <TextBlock Text="{Binding ProjectName}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                                            <TextBlock FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       Margin="10,0,0,0">
                                                                <Run Text="{Binding MessageCount, Mode=OneWay}"/>
                                                                <Run Text="messages"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <Button x:Name="WbContinueChatBtn"
                                                Content="Continue"
                                                Style="{StaticResource PrimaryButton}"
                                                Click="WbContinueChat_Click"
                                                Padding="16,6" Margin="0,10,0,0"
                                                IsEnabled="False"
                                                HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <!-- Section 4: General Chat -->
                                <Border Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonUp="WbGeneralChat_Click"
                                        Margin="0,0,0,8">
                                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
                                        <Run Text="Or start a"/>
                                        <Run Text="General Chat" Foreground="{StaticResource PrimaryBrush}"
                                             TextDecorations="Underline"/>
                                        <Run Text="without project binding"/>
                                    </TextBlock>
                                </Border>

                                <!-- Hint -->
                                <TextBlock Text="Press Enter for new chat"
                                           FontSize="11" FontStyle="Italic"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"/>

                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Border>


                <!-- Message queue -->
                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceBrush}"
                        Padding="8,4"
                        Visibility="{Binding HasQueuedMessages, Converter={StaticResource BoolToVis}}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="Queued messages:" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding MessageQueue}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SurfaceLightBrush}"
                                            CornerRadius="4" Padding="8,4" Margin="0,0,0,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#x23F3;" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Text}"
                                                       FontSize="12" TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource TextBrush}"
                                                       VerticalAlignment="Center"/>
                                            <!-- Send now: cancel current + send this -->
                                            <Border Grid.Column="2" Cursor="Hand" Background="Transparent"
                                                    Margin="4,0,0,0" ToolTip="Send now (cancel current task)">
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftClick"
                                                                  Command="{Binding DataContext.ActiveTab.SendQueuedNowCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <TextBlock Text="&#x25B6;" FontSize="10"
                                                           Foreground="{StaticResource SuccessBrush}"
                                                           VerticalAlignment="Center" Padding="2,0"/>
                                            </Border>
                                            <!-- Return to input textbox -->
                                            <Border Grid.Column="3" Cursor="Hand" Background="Transparent"
                                                    Margin="4,0,0,0" ToolTip="Return to input (edit message)">
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftClick"
                                                                  Command="{Binding DataContext.ActiveTab.ReturnQueuedToInputCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <TextBlock Text="&#x21A9;" FontSize="12"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           VerticalAlignment="Center" Padding="2,0"/>
                                            </Border>
                                            <!-- Delete from queue -->
                                            <Button Grid.Column="4" Style="{StaticResource ChipCloseButton}"
                                                    Command="{Binding DataContext.ActiveTab.RemoveQueuedMessageCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Remove from queue"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Attachments bar -->
                <Border Grid.Row="2"
                        Background="{StaticResource SurfaceBrush}"
                        Padding="8,4"
                        Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVis}}"
                        x:Name="AttachmentBar">
                    <ItemsControl ItemsSource="{Binding Attachments}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ChipBorder}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding FileTypeIcon}" FontSize="12" Margin="0,0,4,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding FileName}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <!-- Preview button for images -->
                                        <Button Content="&#x1F441;" FontSize="11" Padding="4,0"
                                                Margin="4,0,0,0" Cursor="Hand"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.ActiveTab.PreviewAttachmentCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Preview image">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Style="{StaticResource ChipCloseButton}"
                                                Command="{Binding DataContext.ActiveTab.RemoveAttachmentCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- CTA hint -->
                <Border Grid.Row="3"
                        Padding="12,6"
                        Visibility="{Binding HasCta, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding CtaText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center"
                               Opacity="0.85"/>
                </Border>

                <!-- New Chat / History buttons + separator + Use Reviewer + Auto Plan toggles -->
                <Grid Grid.Row="4" Margin="16,4,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="New Chat"
                            Command="{Binding NewSessionCommand}"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="11" Padding="8,3"
                            BorderBrush="#5BA65B" BorderThickness="1"
                            ToolTip="Start a new chat (Ctrl+N)"
                            VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Grid.Column="1"
                            Content="History"
                            Click="MenuItem_ChatHistory_Click"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="11" Padding="8,3"
                            ToolTip="Browse and reopen previous conversations"
                            VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Grid.Column="2"
                            Content="{Binding DataContext.TeamButtonText, RelativeSource={RelativeSource AncestorType=Window}}"
                            Command="{Binding DataContext.ToggleTeamPanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="11" Padding="8,3"
                            BorderBrush="#5BA65B" BorderThickness="1"
                            ToolTip="Toggle Team pipeline panel"
                            VerticalAlignment="Center" Margin="0,0,8,0"
                            Visibility="{Binding DataContext.HasTeamTasks, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                    <!-- Vertical separator -->
                    <Rectangle Grid.Column="3" Width="1" Height="16"
                               Fill="{StaticResource BorderBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <CheckBox Grid.Column="4"
                              IsChecked="{Binding UseReviewer, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left"
                              Cursor="Hand">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="CheckBorder" Width="14" Height="14" CornerRadius="2"
                                                        BorderBrush="{StaticResource ErrorBrush}"
                                                        BorderThickness="1"
                                                        Background="Transparent"
                                                        VerticalAlignment="Center" Margin="0,0,5,0">
                                                    <TextBlock x:Name="Check" Text="&#x2713;" FontSize="10"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Visibility="Collapsed"/>
                                                </Border>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource TextSecondaryBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </CheckBox.Style>
                        <TextBlock x:Name="ReviewerLabel" Text="Use Reviewer" FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseReviewer}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </CheckBox>
                    <!-- Auto-confirm Plan Mode toggle -->
                    <CheckBox Grid.Column="5"
                              Style="{StaticResource InlineCheckBox}"
                              IsChecked="{Binding AutoConfirmEnabled, Mode=TwoWay}"
                              Margin="8,0,0,0"
                              ToolTip="Automatically approve Claude's plan and start implementation. Auto-disables if a loop is detected.">
                        <TextBlock Text="Auto Plan" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </CheckBox>
                </Grid>

                <!-- Input area -->
                <Grid Grid.Row="5" Margin="8,0,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="10,8"
                                x:Name="ComposerBorder">
                            <views:MessageComposerControl
                                x:Name="ComposerControl"
                                ComposerBlocks="{Binding ComposerBlocks}"
                                IsEnabled="{Binding Update.IsUpdating, Converter={StaticResource InverseBool}}"
                                MaxHeight="180"
                                MinHeight="22"
                                VerticalAlignment="Stretch"/>
                        </Border>
                        <!-- Placeholder text -->
                        <TextBlock Text="Type your message here... (Enter to send, Shift+Enter for newline)"
                                   IsHitTestVisible="False"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Cascadia Code,Consolas,Courier New"
                                   FontSize="13"
                                   FontStyle="Italic"
                                   Margin="12,10,0,0"
                                   VerticalAlignment="Top">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsComposerEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Autocomplete popup -->
                        <Popup x:Name="AutocompletePopup"
                               PlacementTarget="{Binding ElementName=ComposerBorder}"
                               Placement="Relative"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               MaxHeight="280">
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="0,4">
                                <ListBox x:Name="AutocompleteList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource TextBrush}"
                                         FontFamily="Cascadia Code,Consolas,Courier New"
                                         FontSize="13"
                                         MaxHeight="260"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bd" Background="Transparent" Padding="8,4">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background"
                                                                        Value="{StaticResource MenuHighlightBrush}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background"
                                                                        Value="{StaticResource SurfaceLightBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Bottom">
                        <!-- Finalize Actions collapsed label (above Send) -->
                        <Border Cursor="Hand" Background="Transparent"
                                Margin="0,0,0,4"
                                Visibility="{Binding FinalizeActions.ShowFinalizeActionsLabel, Converter={StaticResource BoolToVis}}"
                                MouseLeftButtonUp="FinalizeActions_Click">
                            <TextBlock x:Name="FinalizeLabelText"
                                       Text="&#x26A1; Finalize Actions &#x25B2;" FontSize="11"
                                       Foreground="{StaticResource WarningBrush}"
                                       HorizontalAlignment="Center"
                                       Padding="4,2"
                                       ToolTip="Open finalize actions panel">
                                <TextBlock.Resources>
                                    <Storyboard x:Key="BlinkStoryboard" RepeatBehavior="10x">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0.2" Duration="0:0:0.25"
                                                         AutoReverse="True"/>
                                    </Storyboard>
                                </TextBlock.Resources>
                            </TextBlock>
                        </Border>
                        <Button Content="Send"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SendCommand}"
                                IsEnabled="{Binding Update.IsUpdating, Converter={StaticResource InverseBool}}"
                                Margin="0,0,0,4"/>
                    </StackPanel>
                </Grid>

                <!-- Background tasks panel -->
                <Border Grid.Row="6"
                        Background="{StaticResource SurfaceBrush}"
                        Padding="8,3"
                        Visibility="{Binding HasBackgroundTasks, Converter={StaticResource BoolToVis}}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <Expander IsExpanded="True" Foreground="{StaticResource TextSecondaryBrush}">
                        <Expander.Header>
                            <TextBlock Text="{Binding BackgroundTasksHeaderText}" FontSize="11"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <ItemsControl ItemsSource="{Binding BackgroundTasks}" Margin="4,2,0,2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:BackgroundTaskViewModel}">
                                    <Border Margin="0,1" Padding="4,3"
                                            Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status icon -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding StatusIcon}"
                                                       FontSize="12" Margin="0,0,6,0"
                                                       VerticalAlignment="Center"/>

                                            <!-- Description -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>

                                            <!-- Elapsed time -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ElapsedText}"
                                                       FontSize="11" Margin="8,0"
                                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>

                                            <!-- Send to Claude / Sent indicator -->
                                            <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                        Visibility="{Binding HasOutput, Converter={StaticResource BoolToVis}}"
                                                        VerticalAlignment="Center">
                                                <Button Content="Send to Claude"
                                                        FontSize="10" Padding="6,1"
                                                        Margin="0,0,4,0"
                                                        Style="{StaticResource LinkButton}"
                                                        Command="{Binding DataContext.ActiveTab.SendBgTaskOutputCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Visibility>
                                                        <Binding Path="IsSent"
                                                                 Converter="{StaticResource BoolToVis}"
                                                                 ConverterParameter="Invert"/>
                                                    </Button.Visibility>
                                                </Button>
                                                <TextBlock Text="Sent" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding IsSent, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>

                                            <!-- Dismiss button (for completed tasks) -->
                                            <Button Grid.Column="4"
                                                    Content="&#x2715;" FontSize="10"
                                                    Padding="4,0" Margin="0"
                                                    ToolTip="Dismiss"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand"
                                                    Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"
                                                    Command="{Binding DataContext.ActiveTab.DismissBgTaskCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{StaticResource SurfaceLightBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </Border>

                <!-- Changed files indicator -->
                <Border Grid.Row="7"
                        Background="{StaticResource SurfaceBrush}"
                        Padding="8,3"
                        Visibility="{Binding HasChangedFiles, Converter={StaticResource BoolToVis}}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <Expander IsExpanded="False" Foreground="{StaticResource TextSecondaryBrush}">
                        <Expander.Header>
                            <TextBlock Text="{Binding ChangedFilesText}" FontSize="11"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Expander.Header>
                        <ItemsControl ItemsSource="{Binding ChangedFiles}" Margin="16,2,0,2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Cursor="Hand" Background="Transparent"
                                            Margin="0,1" Padding="2,1"
                                            ToolTip="Click to view changes">
                                        <Border.InputBindings>
                                            <MouseBinding Gesture="LeftClick"
                                                          Command="{Binding DataContext.ActiveTab.ViewChangedFileCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   FontFamily="Cascadia Code,Consolas,Courier New"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   TextDecorations="Underline"/>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{StaticResource SurfaceLightBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </Border>

                    </Grid> <!-- End of chat panel -->

                </Grid> <!-- End of content switching area -->

                <!-- ═══ Team Pipeline popup (compact, bottom-right) ═══ -->
                <Border Grid.RowSpan="2" Panel.ZIndex="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Width="520" MaxHeight="500"
                        Margin="0,0,4,4"
                        CornerRadius="8"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Visibility="{Binding DataContext.IsTeamPanelVisible,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Header -->
                            <RowDefinition Height="*"/>     <!-- Project sections -->
                        </Grid.RowDefinitions>

                        <!-- Header bar -->
                        <Border Grid.Row="0" Padding="12,8"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="Team Pipeline"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right"
                                        Content="&#x2715;" FontSize="14"
                                        Padding="6,2" Cursor="Hand"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Background="Transparent" BorderThickness="0"
                                        Command="{Binding DataContext.ToggleTeamPanelCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="Close Team panel"/>
                            </Grid>
                        </Border>

                        <!-- Scrollable project sections -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      Padding="0,4">
                            <ItemsControl ItemsSource="{Binding DataContext.Tabs,
                                              RelativeSource={RelativeSource AncestorType=Window}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:MainViewModel}">
                                        <Border Margin="0,0,0,2"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Visibility="{Binding Team.HasFeatures, Converter={StaticResource BoolToVis}}">
                                            <!-- Project header + TeamPanelControl -->
                                            <Expander IsExpanded="True">
                                                <Expander.Header>
                                                    <TextBlock Text="{Binding Team.ProjectName}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}"/>
                                                </Expander.Header>
                                                <views:TeamPanelControl DataContext="{Binding Team}"
                                                                        Margin="0,0,0,4"/>
                                            </Expander>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </Grid> <!-- End of content area -->

        </Grid> <!-- End of main body -->

        <!-- Status bar (outer grid, binds through ActiveTab) -->
        <Border Grid.Row="2" Style="{StaticResource StatusBarStyle}" DataContext="{Binding ActiveTab}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="{Binding StatusText, Converter={StaticResource StatusTextBrush}}"
                               VerticalAlignment="Center"/>
                    <!-- Review status badge -->
                    <Border CornerRadius="3"
                            Background="{StaticResource ReviewerBubbleBrush}"
                            BorderBrush="{StaticResource ReviewerAccentBrush}"
                            BorderThickness="1"
                            Padding="6,2" Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding ReviewStatusText, Converter={StaticResource StringToVis}}">
                        <TextBlock Text="{Binding ReviewStatusText}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </Border>
                </StackPanel>
                <!-- Folder block — all grey -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="{Binding ProjectParentPath}"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Opacity="0.7"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding ProjectFolderName}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding EffectiveProjectName, StringFormat=' → {0}'}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               Visibility="{Binding EffectiveProjectName, Converter={StaticResource StringToVis}}"
                               ToolTip="Project being actively modified (detected from file paths)"/>
                </StackPanel>
                <!-- Git block — project name (gold) + git status: (grey) + dirty info (colored) -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0"
                            ToolTip="Git repository status. Commit your changes regularly for safe rollback.">
                    <TextBlock Text="{Binding ProjectFolderName}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               Visibility="{Binding HasGitRepo, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text=" git status: "
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Visibility="{Binding HasGitRepo, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding GitDirtyText}"
                               FontSize="12"
                               Foreground="{Binding GitDirtyText, Converter={StaticResource GitStatusBrush}}"/>
                </StackPanel>
                <!-- Context block — label grey, percentage gold; hidden when no data -->
                <StackPanel Grid.Column="4" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0"
                            ToolTip="Context window usage. Shows what percentage of Claude's memory is used.&#x0a;At 80%+ consider starting a new session."
                            Visibility="{Binding ContextPctText, Converter={StaticResource StringToVis}}">
                    <TextBlock Text="Context window used: "
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ContextPctText}"
                               FontSize="11"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
                <!-- Session block — labels grey, percentages gold (global usage, bound to TabHost) -->
                <Border Grid.Column="5" VerticalAlignment="Center" Margin="0,0,16,0"
                        Background="Transparent"
                        DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                        ToolTip="Usage limits from your Anthropic subscription.&#x0a;Session resets every 5 hours, weekly every 7 days."
                        Visibility="{Binding SessionPctText, Converter={StaticResource StringToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="11" VerticalAlignment="Center">
                            <Run Text="Session: " Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Run Text="{Binding SessionPctText, Mode=OneWay}" Foreground="{StaticResource AccentBrush}"/>
                            <Run Text="{Binding SessionExtraText, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Run Text="Week: " Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Run Text="{Binding WeekPctText, Mode=OneWay}" Foreground="{StaticResource AccentBrush}"/>
                            <Run Text="{Binding WeekExtraText, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Column="7" VerticalAlignment="Center"
                        Background="Transparent"
                        MouseLeftButtonUp="ModelIndicator_Click">
                    <TextBlock Text="{Binding ModelName}"
                               FontSize="12" Foreground="{StaticResource PrimaryBrush}"/>
                    <Border.ContextMenu>
                        <ContextMenu x:Name="ModelContextMenu">
                            <MenuItem Header="Switch to Opus (new session)"
                                      Command="{Binding SwitchToOpusCommand}"
                                      ToolTip="Start a new session with claude-opus model."/>
                        </ContextMenu>
                    </Border.ContextMenu>
                </Border>
                <!-- CLI update badge -->
                <Border Grid.Column="8" VerticalAlignment="Center" Margin="12,0,0,0"
                        Cursor="Hand" Background="Transparent"
                        MouseLeftButtonUp="CliUpdateBadge_Click"
                        ToolTip="A new version of Claude Code CLI is available. Click to update."
                        Visibility="{Binding DataContext.Update.ShowCliUpdateBadge, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="&#x2B06; CLI update" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </Border>
            </Grid>
        </Border>
        <!-- Update overlay (covers entire window during update) -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#DD1e1e2e"
                Panel.ZIndex="101"
                Visibility="{Binding Update.ShowUpdateOverlay, Converter={StaticResource BoolToVis}}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="12" Padding="32"
                    Width="480"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <!-- Title -->
                    <TextBlock Text="Update Available"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,6">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Update.UpdateDownloading}" Value="True">
                                        <Setter Property="Text" Value="Updating..."/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Update.UpdateFailed}" Value="True">
                                        <Setter Property="Text" Value="Update Failed"/>
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Version transition -->
                    <TextBlock Text="{Binding Update.UpdateTitle}"
                               FontSize="14"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,10"/>

                    <!-- Release notes (if any) -->
                    <Border Background="{StaticResource BackgroundBrush}"
                            CornerRadius="6" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="10"
                            MaxHeight="160"
                            Margin="0,0,0,14"
                            Visibility="{Binding Update.UpdateReleaseNotes, Converter={StaticResource BoolToVis}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding Update.UpdateReleaseNotes}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Progress bar (visible during download) -->
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding Update.UpdateProgressPercent, Mode=OneWay}"
                                 Height="8"
                                 Margin="0,0,0,12"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 Background="{StaticResource BackgroundBrush}"
                                 BorderThickness="0"
                                 Visibility="{Binding Update.UpdateDownloading, Converter={StaticResource BoolToVis}}"/>

                    <!-- Status indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock x:Name="UpdateStatusDot" Text="&#x25CF; " FontSize="16"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Update.UpdateDownloading}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="UpdatePulse">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1.0" To="0.3"
                                                                         Duration="0:0:0.8"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="UpdatePulse"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Update.UpdateFailed}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                            <Setter Property="Opacity" Value="1.0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Update.UpdateStatusText}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Warning: don't close (visible during download) -->
                    <TextBlock Text="&#x26A0; Please do not close the application during the update."
                               FontSize="11" FontStyle="Italic"
                               Foreground="#FFE0A0"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"
                               Visibility="{Binding Update.UpdateDownloading, Converter={StaticResource BoolToVis}}"/>

                    <!-- Buttons: Install / Later (before download starts) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,4,0,0"
                                Visibility="{Binding Update.UpdateDownloading, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <!-- Hide buttons when failed too -->
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Update.UpdateFailed}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Content="Install Now"
                                Padding="24,8" Margin="0,0,12,0"
                                Click="UpdateInstall_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource BackgroundBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#5CBF64"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Later"
                                Padding="24,8"
                                Click="UpdateLater_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource BackgroundBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Close button (only visible on failure) -->
                    <Button Content="Close"
                            Padding="24,8"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0"
                            Click="UpdateClose_Click"
                            Visibility="{Binding Update.UpdateFailed, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background"
                                                            Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource BackgroundBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Border>

        <!-- CLI Update overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#DD1e1e2e"
                Panel.ZIndex="102"
                Visibility="{Binding Update.ShowCliUpdateOverlay, Converter={StaticResource BoolToVis}}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="12" Padding="32"
                    Width="520"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <!-- Title -->
                    <TextBlock Text="CLI Update Available"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,6">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Update.CliUpdating}" Value="True">
                                        <Setter Property="Text" Value="Updating CLI..."/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Update.CliUpdateFailed}" Value="True">
                                        <Setter Property="Text" Value="CLI Update Failed"/>
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Version transition -->
                    <TextBlock Text="{Binding Update.CliUpdateTitle}"
                               FontSize="14"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,10"/>

                    <!-- Log viewer (visible during update or after failure) -->
                    <Border Background="{StaticResource BackgroundBrush}"
                            CornerRadius="6" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="10"
                            MaxHeight="200"
                            Margin="0,0,0,14"
                            Visibility="{Binding Update.CliUpdateLog, Converter={StaticResource StringToVis}}">
                        <ScrollViewer x:Name="CliUpdateLogScroller" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding Update.CliUpdateLog}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Status indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock x:Name="CliUpdateStatusDot" Text="&#x25CF; " FontSize="16"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Update.CliUpdating}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="CliUpdatePulse">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1.0" To="0.3"
                                                                         Duration="0:0:0.8"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="CliUpdatePulse"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Update.CliUpdateFailed}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                            <Setter Property="Opacity" Value="1.0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Update.CliUpdateStatusText}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Buttons: Update Now / Later (before update starts) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,4,0,0"
                                Visibility="{Binding Update.CliUpdating, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Update.CliUpdateFailed}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Content="Update Now"
                                Padding="24,8" Margin="0,0,12,0"
                                Click="CliUpdateInstall_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource BackgroundBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#5CBF64"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Later"
                                Padding="24,8"
                                Click="CliUpdateLater_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource BackgroundBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Close button (only visible on failure) -->
                    <Button Content="Close"
                            Padding="24,8"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0"
                            Click="CliUpdateClose_Click"
                            Visibility="{Binding Update.CliUpdateFailed, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background"
                                                            Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource BackgroundBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Border>

        <!-- Dependency install overlay (covers entire window during setup) -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#DD1e1e2e"
                Panel.ZIndex="100"
                Visibility="{Binding ActiveTab.DependencySetup.ShowDependencyOverlay, Converter={StaticResource BoolToVis}}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="12" Padding="32"
                    Width="520"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <!-- Step counter -->
                    <TextBlock Text="{Binding ActiveTab.DependencySetup.DependencyStep}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,4"/>

                    <!-- Title -->
                    <TextBlock Text="{Binding ActiveTab.DependencySetup.DependencyTitle}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,6"/>

                    <!-- Subtitle / description -->
                    <TextBlock Text="{Binding ActiveTab.DependencySetup.DependencySubtitle}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                    <!-- Status indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock x:Name="DepStatusDot" Text="&#x25CF; " FontSize="16"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveTab.DependencySetup.ShowDependencyOverlay}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="DepPulse">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1.0" To="0.3"
                                                                         Duration="0:0:0.8"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="DepPulse"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveTab.DependencySetup.DependencyFailed}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                            <Setter Property="Opacity" Value="1.0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding ActiveTab.DependencySetup.DependencyStatus}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Log output -->
                    <Border Background="{StaticResource BackgroundBrush}"
                            CornerRadius="6" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="8"
                            Height="200">
                        <ScrollViewer x:Name="DepLogScroller" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="DepLogText"
                                       Text="{Binding ActiveTab.DependencySetup.DependencyLog}"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Warning: don't close (hidden when failed) -->
                    <TextBlock Text="&#x26A0; Please do not close the application during installation."
                               FontSize="11" FontStyle="Italic"
                               Foreground="#FFE0A0"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab.DependencySetup.DependencyFailed}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Close button (only visible on failure) -->
                    <Button Content="Close"
                            Padding="24,8"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0"
                            Click="DepCloseButton_Click"
                            Visibility="{Binding ActiveTab.DependencySetup.DependencyFailed, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background"
                                                            Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource BackgroundBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Border>

        <!-- Drag & drop overlay -->
        <Border x:Name="DragDropOverlay"
                Grid.Row="0" Grid.RowSpan="3"
                Background="#CC1e1e2e"
                Panel.ZIndex="200"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="16" Padding="48,36"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#x1F4CE;"
                               FontSize="40"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Drop files to attach"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Files will be sent with your next message"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>
