<Window x:Class="ClaudeCodeWin.HealthCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Health Check"
        Width="600" Height="420"
        MinWidth="500" MinHeight="350"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Health Check" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12">
            System diagnostics for Claude Code for Windows.
        </TextBlock>

        <!-- Loading state -->
        <TextBlock Grid.Row="2" x:Name="LoadingLabel"
                   Text="Running checks..."
                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <ItemsControl Grid.Row="2" x:Name="ResultList" Visibility="Collapsed"
                      Background="{StaticResource SurfaceBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1"
                      Padding="0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,8"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Status icon -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding StatusIcon}"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>

                            <!-- Check name -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"/>

                            <!-- Details -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Details}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       ToolTip="{Binding Details}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Re-check" x:Name="RecheckButton" Click="RecheckButton_Click"
                    Style="{StaticResource PrimaryButton}"
                    Padding="24,6" Margin="0,0,8,0"/>
            <Button Content="Copy" x:Name="CopyButton" Click="CopyButton_Click"
                    Padding="24,6" Margin="0,0,8,0"
                    Background="{StaticResource SurfaceBrush}"
                    Foreground="{StaticResource TextBrush}"
                    BorderBrush="{StaticResource BorderBrush}"/>
            <Button Content="Close" Click="CloseButton_Click"
                    Padding="24,6"
                    Background="{StaticResource SurfaceBrush}"
                    Foreground="{StaticResource TextBrush}"
                    BorderBrush="{StaticResource BorderBrush}"/>
        </StackPanel>
    </Grid>
</Window>
