<Window x:Class="ClaudeCodeWin.ActivationCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activation Code"
        Width="440" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Activation Code"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryBrush}"/>

        <!-- Current status -->
        <Border x:Name="CurrentStatusPanel" Grid.Row="1" Margin="0,16,0,0"
                Padding="12,8" CornerRadius="4"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="CurrentCodeText" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock x:Name="CurrentFeaturesText" FontSize="11" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                <Button Content="Deactivate" Margin="0,8,0,0" Padding="16,4"
                        HorizontalAlignment="Left" Cursor="Hand"
                        Background="Transparent"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Click="Deactivate_Click"/>
            </StackPanel>
        </Border>

        <!-- Enter code -->
        <TextBlock Grid.Row="2" Text="Enter activation code" Margin="0,16,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
        <TextBox x:Name="CodeBox" Grid.Row="3"
                 Padding="8,6" FontSize="16" FontFamily="Consolas"
                 CharacterCasing="Upper" MaxLength="8"
                 Background="{DynamicResource SurfaceBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"/>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="4" Margin="0,8,0,0"
                   FontSize="12" TextWrapping="Wrap"/>

        <!-- Info -->
        <TextBlock Grid.Row="5" Margin="0,12,0,0" TextWrapping="Wrap" FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Bottom">
            Activation codes unlock extra features for your copy of CCW.
            Request a code via GitHub Issues if you need personalized functionality.
        </TextBlock>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Padding="24,8" Margin="0,0,8,0"
                    Background="Transparent"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Cursor="Hand" Click="Close_Click"/>
            <Button x:Name="ActivateButton" Content="Activate" Padding="24,8"
                    Style="{StaticResource PrimaryButton}" Cursor="Hand"
                    Click="Activate_Click"/>
        </StackPanel>
    </Grid>
</Window>
