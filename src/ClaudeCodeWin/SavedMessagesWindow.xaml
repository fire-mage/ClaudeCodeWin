<Window x:Class="ClaudeCodeWin.SavedMessagesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ClaudeCodeWin.Converters"
        Title="Saved Messages"
        Width="600" Height="450"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Saved Messages" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>

        <ListView Grid.Row="1" x:Name="MessageList"
                  Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  MouseDoubleClick="MessageList_MouseDoubleClick">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A2E3A"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#333850"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource AccentBrush}"
                                       Visibility="{Binding Label, Converter={StaticResource StringToVis}}"/>
                            <TextBlock Text="{Binding Preview}" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Use" Padding="8,3" Margin="8,0,4,0"
                                FontSize="11" VerticalAlignment="Center"
                                Style="{StaticResource SecondaryButton}"
                                Click="UseButton_Click"/>
                        <Button Grid.Column="2" Content="&#x2715;" Padding="6,3"
                                FontSize="10" VerticalAlignment="Center"
                                Foreground="{StaticResource ErrorBrush}"
                                Style="{StaticResource SecondaryButton}"
                                Click="DeleteButton_Click"
                                ToolTip="Delete saved message"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="1" x:Name="EmptyMessage"
                   Text="No saved messages yet.&#x0a;Use the &#x2606; button next to Send to save a message."
                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" IsHitTestVisible="False"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Padding="16,6" Style="{StaticResource SecondaryButton}"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
