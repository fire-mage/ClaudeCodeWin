<UserControl x:Class="ClaudeCodeWin.Views.TeamPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ClaudeCodeWin.ViewModels"
             xmlns:converters="clr-namespace:ClaudeCodeWin.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:ExpandArrowConverter x:Key="ExpandArrow"/>

        <!-- Phase item template -->
        <DataTemplate x:Key="PhaseItemTemplate">
            <Grid Margin="0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusIcon}"
                           FontSize="11"
                           FontFamily="Cascadia Code,Consolas,Courier New"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           FontSize="11"
                           Foreground="{StaticResource TextBrush}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusText}"
                           FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
                <TextBlock Grid.Column="3"
                           Text="{Binding TimeText}"
                           FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0"/>
            </Grid>
        </DataTemplate>

        <!-- Feature item template -->
        <DataTemplate x:Key="FeatureItemTemplate" DataType="{x:Type vm:BacklogFeatureVM}">
            <Border Margin="0,2" Padding="8,6"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="4"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Cancel" Click="ContextMenu_CancelFeature"/>
                        <Separator/>
                        <MenuItem Header="Delete" Click="ContextMenu_DeleteFeature"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel>
                    <!-- Feature header (click to expand) -->
                    <Border Background="Transparent" Cursor="Hand"
                            MouseLeftButtonUp="Feature_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Expand/collapse arrow -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding IsExpanded, Converter={StaticResource ExpandArrow}}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding HasPhases, Converter={StaticResource BoolToVis}}"/>

                            <!-- Feature title -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayTitle}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Margin="2,0,0,0"/>

                            <!-- Phase progress -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding PhaseProgressText}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Planner question (for AwaitingUser features) -->
                    <TextBlock Text="{Binding PlannerQuestion}"
                               FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource AccentBrush}"
                               TextWrapping="Wrap"
                               Margin="18,4,0,0"
                               Visibility="{Binding NeedsUserInput, Converter={StaticResource BoolToVis}}"/>

                    <!-- Answer input (for AwaitingUser features) -->
                    <Grid Margin="18,4,0,0"
                          Visibility="{Binding NeedsUserInput, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding AnswerText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource BackgroundBrush}"
                                 Foreground="{StaticResource TextBrush}"
                                 CaretBrush="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 FontSize="11" Padding="6,3"
                                 VerticalContentAlignment="Center"
                                 KeyDown="AnswerTextBox_KeyDown"/>
                        <Button Grid.Column="1" Content="Send"
                                Padding="8,3" Margin="4,0,0,0"
                                FontSize="11"
                                Style="{StaticResource SubTabToolButton}"
                                Click="SendAnswer_Click"/>
                    </Grid>

                    <!-- Expandable phases list -->
                    <ItemsControl ItemsSource="{Binding PhaseItems}"
                                  ItemTemplate="{StaticResource PhaseItemTemplate}"
                                  Margin="18,4,0,0"
                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar: Add Idea input + buttons -->
        <Border Grid.Row="0" Padding="8,6"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="IdeaBox"
                             Text="{Binding AddIdeaText, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource BackgroundBrush}"
                             Foreground="{StaticResource TextBrush}"
                             CaretBrush="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             FontSize="12" Padding="8,4"
                             VerticalContentAlignment="Center"
                             KeyDown="AddIdeaTextBox_KeyDown"/>
                    <TextBlock Text="Add a new idea..."
                               IsHitTestVisible="False"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Visibility="{Binding Text.Length, ElementName=IdeaBox,
                                            Converter={StaticResource BoolToVis},
                                            ConverterParameter=Invert}"/>
                </Grid>

                <Button Grid.Column="1" Content="+ Add"
                        Padding="8,4" Margin="4,0,0,0"
                        Style="{StaticResource SubTabToolButton}"
                        Command="{Binding AddIdeaCommand}"/>

                <Button Grid.Column="2" Content="&#x21BB;"
                        ToolTip="Refresh"
                        Padding="6,4" Margin="4,0,0,0"
                        Style="{StaticResource ExplorerToolButton}"
                        Command="{Binding RefreshCommand}"/>
            </Grid>
        </Border>

        <!-- Orchestrator control bar -->
        <Border Grid.Row="1" Padding="8,4"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="&#x25B6; Start"
                        ToolTip="Start or resume orchestrator"
                        Padding="8,3" Margin="0,0,4,0"
                        FontSize="11"
                        Style="{StaticResource SubTabToolButton}"
                        Command="{Binding StartOrchestratorCommand}"/>

                <Button Grid.Column="1" Content="&#x23F8; Pause"
                        ToolTip="Finish current phase, then pause"
                        Padding="8,3" Margin="0,0,4,0"
                        FontSize="11"
                        Style="{StaticResource SubTabToolButton}"
                        Command="{Binding PauseOrchestratorCommand}"/>

                <Button Grid.Column="2" Content="&#x23E9; Hard Pause"
                        ToolTip="Stop current session immediately (phase restarts on resume)"
                        Padding="8,3" Margin="0,0,4,0"
                        FontSize="11"
                        Style="{StaticResource SubTabToolButton}"
                        Command="{Binding HardPauseOrchestratorCommand}"/>

                <Button Grid.Column="3" Content="&#x23F9; Stop"
                        ToolTip="Stop orchestrator completely"
                        Padding="8,3" Margin="0,0,4,0"
                        FontSize="11"
                        Style="{StaticResource SubTabToolButton}"
                        Command="{Binding StopOrchestratorCommand}"/>

                <TextBlock Grid.Column="5"
                           Text="{Binding OrchestratorStatusText}"
                           FontSize="11"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Health strip (active sessions) -->
        <Border Grid.Row="2" Padding="8,3"
                Background="{StaticResource BackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding HasActiveSession, Converter={StaticResource BoolToVis}}">
            <ItemsControl ItemsSource="{Binding SessionHealthItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <TextBlock Text="{Binding HealthIcon}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasIssue}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding Role}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Detail}"
                                       FontSize="10" Margin="4,0,0,0"
                                       Foreground="{StaticResource WarningBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding HasIssue, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding Elapsed}"
                                       FontSize="10" Margin="4,0,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Feature list grouped by status -->
        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource BackgroundBrush}">
            <StackPanel Margin="8,4">

                <!-- Empty state -->
                <TextBlock Text="No features yet. Add an idea above to get started."
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,32,0,0"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>

                <!-- In Progress -->
                <StackPanel Visibility="{Binding HasInProgress, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="In Progress" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,8,0,4"/>
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding InProgressFeatures}"
                                  ItemTemplate="{StaticResource FeatureItemTemplate}"/>
                </StackPanel>

                <!-- Awaiting Your Input -->
                <StackPanel Visibility="{Binding HasAwaitingUser, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Awaiting Your Input" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,12,0,4"/>
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding AwaitingUserFeatures}"
                                  ItemTemplate="{StaticResource FeatureItemTemplate}"/>
                </StackPanel>

                <!-- Planned -->
                <StackPanel Visibility="{Binding HasPlanned, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Planned" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,12,0,4"/>
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding PlannedFeatures}"
                                  ItemTemplate="{StaticResource FeatureItemTemplate}"/>
                </StackPanel>

                <!-- New Ideas -->
                <StackPanel Visibility="{Binding HasRaw, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="New Ideas" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,12,0,4"/>
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding RawFeatures}"
                                  ItemTemplate="{StaticResource FeatureItemTemplate}"/>
                </StackPanel>

                <!-- Completed -->
                <StackPanel Visibility="{Binding HasCompleted, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Completed" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}"
                               Margin="0,12,0,4"/>
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding CompletedFeatures}"
                                  ItemTemplate="{StaticResource FeatureItemTemplate}"/>
                </StackPanel>

                <!-- Manager Chat (collapsible) -->
                <Border Background="Transparent" Cursor="Hand" Margin="0,12,0,0"
                        MouseLeftButtonUp="ManagerHeader_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ManagerArrow" Text="&#x25B8;"
                                   FontSize="10" Margin="0,0,4,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Manager" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="Start"
                                Padding="6,2" Margin="4,0,0,0"
                                FontSize="10"
                                Style="{StaticResource SubTabToolButton}"
                                Command="{Binding StartManagerCommand}"/>
                        <Button Grid.Column="3" Content="Stop"
                                Padding="6,2" Margin="4,0,0,0"
                                FontSize="10"
                                Style="{StaticResource SubTabToolButton}"
                                Command="{Binding StopManagerCommand}"/>
                    </Grid>
                </Border>
                <StackPanel x:Name="ManagerPanel" Visibility="Collapsed" Margin="0,4,0,0">
                    <!-- Chat log -->
                    <TextBox x:Name="ManagerChatBox"
                             Text="{Binding ManagerChatLog, Mode=OneWay}"
                             Background="{StaticResource BackgroundBrush}"
                             Foreground="{StaticResource TextBrush}"
                             CaretBrush="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             FontFamily="Cascadia Code,Consolas,Courier New"
                             FontSize="11"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             MaxHeight="200"
                             VerticalScrollBarVisibility="Auto"/>

                    <!-- Streaming response -->
                    <TextBlock Text="{Binding ManagerResponse}"
                               FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource AccentBrush}"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0"
                               Visibility="{Binding IsManagerActive, Converter={StaticResource BoolToVis}}"/>

                    <!-- Input -->
                    <Grid Margin="0,4,0,0"
                          Visibility="{Binding IsManagerActive, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ManagerInputText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource BackgroundBrush}"
                                 Foreground="{StaticResource TextBrush}"
                                 CaretBrush="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 FontSize="11" Padding="6,3"
                                 VerticalContentAlignment="Center"
                                 KeyDown="ManagerInput_KeyDown"/>
                        <Button Grid.Column="1" Content="Send"
                                Padding="8,3" Margin="4,0,0,0"
                                FontSize="11"
                                Style="{StaticResource SubTabToolButton}"
                                Command="{Binding SendManagerMessageCommand}"/>
                    </Grid>
                </StackPanel>

                <!-- Orchestrator Log (collapsible) -->
                <Border Background="Transparent" Cursor="Hand" Margin="0,12,0,0"
                        MouseLeftButtonUp="LogHeader_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="LogArrow" Text="&#x25B8;"
                                   FontSize="10" Margin="0,0,4,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Orchestrator Log" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <TextBox x:Name="LogTextBox"
                         Text="{Binding OrchestratorLog, Mode=OneWay}"
                         Background="{StaticResource BackgroundBrush}"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         CaretBrush="{StaticResource TextBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1"
                         FontFamily="Cascadia Code,Consolas,Courier New"
                         FontSize="10"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         MaxHeight="160"
                         Margin="0,4,0,0"
                         Visibility="Collapsed"
                         VerticalScrollBarVisibility="Auto"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
