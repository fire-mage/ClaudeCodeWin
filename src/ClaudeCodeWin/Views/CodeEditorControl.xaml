<UserControl x:Class="ClaudeCodeWin.Views.CodeEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ClaudeCodeWin.Views">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Search/Replace bar -->
            <RowDefinition Height="*"/>     <!-- Editor area -->
        </Grid.RowDefinitions>

        <!-- Search/Replace bar -->
        <Border x:Name="SearchBar" Grid.Row="0" Visibility="Collapsed"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Search row -->
                    <RowDefinition Height="Auto"/>  <!-- Replace row -->
                </Grid.RowDefinitions>

                <!-- Search row -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBox x:Name="SearchTextBox" Width="240"
                             Padding="6,3" FontSize="12"
                             FontFamily="Cascadia Code,Consolas,Courier New"
                             Background="{StaticResource BackgroundBrush}"
                             Foreground="{StaticResource TextBrush}"
                             CaretBrush="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             TextChanged="SearchTextBox_TextChanged"
                             PreviewKeyDown="SearchTextBox_PreviewKeyDown"/>
                    <TextBlock x:Name="MatchCountLabel" Text="" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,4,0" MinWidth="50"/>
                    <Button Content="&#x25B2;" ToolTip="Previous (Shift+Enter)"
                            Click="FindPrevious_Click" Padding="6,2" Margin="2,0"
                            Style="{StaticResource ExplorerToolButton}"/>
                    <Button Content="&#x25BC;" ToolTip="Next (Enter)"
                            Click="FindNext_Click" Padding="6,2" Margin="2,0"
                            Style="{StaticResource ExplorerToolButton}"/>
                    <Button x:Name="ToggleReplaceButton" Content="&#x21C5;" ToolTip="Toggle Replace (Ctrl+H)"
                            Click="ToggleReplace_Click" Padding="6,2" Margin="2,0"
                            Style="{StaticResource ExplorerToolButton}"/>
                    <Button Content="&#x2715;" ToolTip="Close (Escape)"
                            Click="CloseSearch_Click" Padding="6,2" Margin="2,0"
                            Style="{StaticResource ExplorerToolButton}"/>
                </StackPanel>

                <!-- Replace row -->
                <StackPanel x:Name="ReplaceRow" Grid.Row="1" Orientation="Horizontal"
                            Visibility="Collapsed" Margin="0,4,0,0">
                    <TextBox x:Name="ReplaceTextBox" Width="240"
                             Padding="6,3" FontSize="12"
                             FontFamily="Cascadia Code,Consolas,Courier New"
                             Background="{StaticResource BackgroundBrush}"
                             Foreground="{StaticResource TextBrush}"
                             CaretBrush="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             PreviewKeyDown="ReplaceTextBox_PreviewKeyDown"/>
                    <Button Content="Replace" ToolTip="Replace current match"
                            Click="ReplaceOne_Click" Padding="6,2" Margin="8,0,2,0"
                            Style="{StaticResource ExplorerToolButton}"/>
                    <Button Content="Replace All" ToolTip="Replace all matches"
                            Click="ReplaceAll_Click" Padding="6,2" Margin="2,0"
                            Style="{StaticResource ExplorerToolButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Editor area: line numbers + text editor -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Line numbers gutter -->
                <ColumnDefinition Width="*"/>     <!-- Editor -->
            </Grid.ColumnDefinitions>

            <!-- Line numbers gutter -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    MinWidth="40">
                <Canvas ClipToBounds="True">
                    <TextBlock x:Name="LineNumbers"
                               FontFamily="Cascadia Code,Consolas,Courier New"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextAlignment="Right"
                               Padding="8,8,8,0"/>
                </Canvas>
            </Border>

            <!-- Text editor with syntax highlight layer -->
            <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
                <!-- Syntax highlighting layer (behind TextBox) -->
                <views:SyntaxHighlightLayer x:Name="HighlightLayer"
                                             ClipToBounds="True"/>

                <!-- Text editor -->
                <TextBox x:Name="Editor"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code,Consolas,Courier New"
                         FontSize="14"
                         Background="Transparent"
                         Foreground="{StaticResource TextBrush}"
                         CaretBrush="{StaticResource TextBrush}"
                         SelectionBrush="{StaticResource SelectionBrush}"
                         BorderThickness="0"
                         Padding="8,8"
                         TextChanged="Editor_TextChanged"
                         SelectionChanged="Editor_SelectionChanged"
                         PreviewKeyDown="Editor_PreviewKeyDown"/>

                <!-- IntelliSense completion popup -->
                <Popup x:Name="CompletionPopup"
                       PlacementTarget="{Binding ElementName=Editor}"
                       Placement="Relative"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       PopupAnimation="None"
                       MaxHeight="240">
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="0,2">
                        <ListBox x:Name="CompletionList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 FontFamily="Cascadia Code,Consolas,Courier New"
                                 FontSize="13"
                                 MaxHeight="220"
                                 Focusable="False"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 MouseDoubleClick="CompletionList_MouseDoubleClick">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Background="Transparent" Padding="6,3">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource SurfaceLightBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource MenuHighlightBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource SurfaceLightBrush}"
                                                CornerRadius="2" Padding="4,1" Margin="0,0,6,0"
                                                MinWidth="22" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding KindBadge}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="{Binding KindBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Detail}" Margin="12,0,0,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
