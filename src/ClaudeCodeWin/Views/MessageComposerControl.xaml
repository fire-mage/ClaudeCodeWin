<UserControl x:Class="ClaudeCodeWin.Views.MessageComposerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ClaudeCodeWin.Models"
             Focusable="False">
    <UserControl.Resources>
        <!-- Invisible TextBox style: no border, blends into the composer surface -->
        <Style x:Key="ComposerTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Courier New"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="MinHeight" Value="22"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Focusable="False">
        <ItemsControl x:Name="BlocksControl"
                      Focusable="False">
            <ItemsControl.Resources>
                <!-- Template for text blocks -->
                <DataTemplate DataType="{x:Type models:TextComposerBlock}">
                    <TextBox Style="{StaticResource ComposerTextBox}"
                             Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{Binding}"
                             GotFocus="TextBlock_GotFocus"
                             LostFocus="TextBlock_LostFocus"
                             TextChanged="TextBlock_TextChanged"
                             PreviewKeyDown="TextBlock_PreviewKeyDown"/>
                </DataTemplate>

                <!-- Template for inline image blocks -->
                <DataTemplate DataType="{x:Type models:ImageComposerBlock}">
                    <Border Background="{StaticResource SurfaceLightBrush}"
                            CornerRadius="4" Padding="6,4" Margin="0,4"
                            Tag="{Binding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Thumbnail -->
                            <Border Grid.Column="0" Width="60" Height="40"
                                    CornerRadius="3" ClipToBounds="True"
                                    Margin="0,0,8,0">
                                <Image Source="{Binding FilePath}"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <!-- Icon -->
                            <TextBlock Grid.Column="1" Text="&#x1F5BC;" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <!-- File name -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding FileName}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <!-- Remove button -->
                            <Button Grid.Column="3"
                                    Content="&#x2715;" FontSize="10"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="4,2"
                                    Margin="4,0,0,0"
                                    Click="RemoveImage_Click"
                                    Tag="{Binding}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.Resources>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
