<Window x:Class="ClaudeCodeWin.Views.TeamChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ClaudeCodeWin.Views"
        Title="Team Live Chat"
        Width="900" Height="700"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Padding="12,8"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="{Binding ActiveFeatureTitle}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryBrush}"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Chat -->
        <views:ChatControl Messages="{Binding TeamChatMessages}"/>
    </DockPanel>
</Window>
