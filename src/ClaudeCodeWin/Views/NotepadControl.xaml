<UserControl x:Class="ClaudeCodeWin.Views.NotepadControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="100"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Column 0: Note list panel -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                <RowDefinition Height="*"/>     <!-- Note list -->
            </Grid.RowDefinitions>

            <!-- Toolbar: normal mode -->
            <Border Grid.Row="0" Padding="4,2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <StackPanel Orientation="Horizontal">
                    <Button Content="+ New" ToolTip="New Note"
                            Command="{Binding CreateNoteCommand}"
                            Style="{StaticResource ExplorerToolButton}"
                            Padding="6,2" Margin="0,0,2,0"/>
                    <Button Content="Rename" ToolTip="Rename Note (F2)"
                            Command="{Binding RenameNoteCommand}"
                            Style="{StaticResource ExplorerToolButton}"
                            Padding="6,2" Margin="0,0,2,0"/>
                    <Button Content="Delete" ToolTip="Delete Note"
                            Command="{Binding DeleteNoteCommand}"
                            Style="{StaticResource ExplorerToolButton}"
                            Padding="6,2"/>
                </StackPanel>
            </Border>

            <!-- Toolbar: rename mode -->
            <Border Grid.Row="0" Padding="4,2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="RenameTextBox"
                             Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBox}"
                             MinWidth="100" Padding="4,2" Margin="0,0,4,0"
                             VerticalContentAlignment="Center"
                             KeyDown="RenameTextBox_KeyDown"/>
                    <Button Content="OK" ToolTip="Confirm rename"
                            Command="{Binding CommitRenameCommand}"
                            Style="{StaticResource ExplorerToolButton}"
                            Padding="6,2" Margin="0,0,2,0"/>
                    <Button Content="Cancel" ToolTip="Cancel rename"
                            Command="{Binding CancelRenameCommand}"
                            Style="{StaticResource ExplorerToolButton}"
                            Padding="6,2"/>
                </StackPanel>
            </Border>

            <!-- Note list -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Notes}"
                     SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                     Background="{StaticResource BackgroundBrush}"
                     Foreground="{StaticResource TextBrush}"
                     BorderThickness="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="Transparent"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Hover only when NOT selected -->
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{StaticResource SurfaceBrush}"/>
                                        </MultiTrigger>
                                        <!-- Selected always wins -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{StaticResource SurfaceLightBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="13"
                                   FontFamily="Cascadia Code,Consolas,Courier New"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- GridSplitter -->
        <GridSplitter Grid.Column="1" Width="3"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- Column 2: Text editor -->
        <TextBox Grid.Column="2"
                 Text="{Binding NoteContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource InputTextBox}"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="14"
                 Padding="8"
                 BorderThickness="0"/>
    </Grid>
</UserControl>
