<UserControl x:Class="ClaudeCodeWin.Views.NotepadControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ClaudeCodeWin.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="100"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Column 0: Note list panel -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                <RowDefinition Height="*"/>     <!-- Note list -->
            </Grid.RowDefinitions>

            <!-- Toolbar: normal mode -->
            <Border Grid.Row="0" Padding="4,2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <StackPanel Orientation="Horizontal">
                    <Button Content="+ New" ToolTip="New Note"
                            Command="{Binding CreateNoteCommand}"
                            Style="{StaticResource ExplorerToolButton}"
                            Padding="6,2"/>
                </StackPanel>
            </Border>

            <!-- Toolbar: rename mode -->
            <Border Grid.Row="0" Padding="4,2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="RenameTextBox"
                             Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBox}"
                             MinWidth="100" Padding="4,2" Margin="0,0,4,0"
                             VerticalContentAlignment="Center"
                             KeyDown="RenameTextBox_KeyDown"/>
                    <Button Content="OK" ToolTip="Confirm rename"
                            Command="{Binding CommitRenameCommand}"
                            Style="{StaticResource ExplorerToolButton}"
                            Padding="6,2" Margin="0,0,2,0"/>
                    <Button Content="Cancel" ToolTip="Cancel rename"
                            Command="{Binding CancelRenameCommand}"
                            Style="{StaticResource ExplorerToolButton}"
                            Padding="6,2"/>
                </StackPanel>
            </Border>

            <!-- Note list -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Notes}"
                     SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                     Background="{StaticResource BackgroundBrush}"
                     Foreground="{StaticResource TextBrush}"
                     BorderThickness="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="Transparent"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Hover only when NOT selected -->
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{StaticResource SurfaceBrush}"/>
                                        </MultiTrigger>
                                        <!-- Selected always wins -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{StaticResource SurfaceLightBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding}" FontSize="13"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="NoteMenuBtn" Grid.Column="1" Content="&#x22EE;" ToolTip="Actions"
                                    FontSize="14" FontWeight="Bold"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Padding="6,0" Margin="4,0,0,0"
                                    VerticalAlignment="Center" Cursor="Hand"
                                    Click="NoteMenuButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="MenuBd" Background="Transparent"
                                                            Padding="{TemplateBinding Padding}"
                                                            CornerRadius="3">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="MenuBd" Property="Background"
                                                                    Value="{StaticResource SurfaceLightBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <Button.ContextMenu>
                                    <ContextMenu Background="{StaticResource SurfaceBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}"
                                                 Foreground="{StaticResource TextBrush}">
                                        <MenuItem Header="Rename (F2)" Click="NoteContextMenu_Rename"/>
                                        <MenuItem Header="Delete" Click="NoteContextMenu_Delete"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="NoteMenuBtn" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- GridSplitter -->
        <GridSplitter Grid.Column="1" Width="3"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- Column 2: Text editor with overlay Save button -->
        <Grid Grid.Column="2">
            <TextBox Text="{Binding NoteContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputTextBox}"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="14"
                     Padding="8,8,8,40"
                     BorderThickness="0"/>
            <Button Content="Save" ToolTip="Save Note (Ctrl+S)"
                    Command="{Binding SaveNoteCommand}"
                    Style="{StaticResource ExplorerToolButton}"
                    Padding="8,4" Margin="0,0,22,12"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Visibility="{Binding SelectedNote, Converter={StaticResource StringToVis}}"/>
        </Grid>
    </Grid>
</UserControl>
