<Window x:Class="ClaudeCodeWin.WorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workspace Manager"
        Width="560" Height="480"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Workspace Name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Workspace Name"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="NameTextBox"
                     Padding="8,6"
                     FontSize="13"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"/>
        </StackPanel>

        <!-- Projects Header + Add Buttons -->
        <DockPanel Grid.Row="1" Margin="0,0,0,6">
            <TextBlock Text="Projects"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Add Folder..."
                        Padding="10,4" Margin="0,0,6,0"
                        Background="Transparent"
                        Foreground="{DynamicResource TextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Cursor="Hand"
                        Click="AddFolder_Click"/>
                <Button Content="From Registry..."
                        Padding="10,4"
                        Background="Transparent"
                        Foreground="{DynamicResource TextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Cursor="Hand"
                        Click="AddFromRegistry_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Projects List -->
        <ListBox x:Name="ProjectsList" Grid.Row="2"
                 Background="{DynamicResource InputBackgroundBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 SelectionMode="Single"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Primary indicator -->
                        <RadioButton Grid.Column="0"
                                     GroupName="PrimaryProject"
                                     IsChecked="{Binding IsPrimary, Mode=TwoWay}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"
                                     ToolTip="Set as primary (CLI working directory)"
                                     Checked="PrimaryRadio_Checked"/>

                        <!-- Path + Name -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="{Binding Path}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Role -->
                        <TextBox Grid.Column="2"
                                 Text="{Binding Role, UpdateSourceTrigger=PropertyChanged}"
                                 Width="90" Padding="4,2" Margin="8,0,0,0"
                                 FontSize="11"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 ToolTip="Role (e.g. backend, frontend)"
                                 VerticalAlignment="Center"/>

                        <!-- Remove button -->
                        <Button Grid.Column="4" Content="✕"
                                Padding="6,2" Margin="6,0,0,0"
                                Background="Transparent"
                                Foreground="{DynamicResource ErrorBrush}"
                                BorderThickness="0" Cursor="Hand"
                                ToolTip="Remove from workspace"
                                VerticalAlignment="Center"
                                Click="RemoveProject_Click"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Info text -->
        <TextBlock Grid.Row="3" Margin="0,8,0,0"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   Text="Select one project as primary (CLI working directory). Related projects provide context to Claude but don't run CLI processes."/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="DeleteButton" Content="Delete Workspace"
                    Padding="16,8" Margin="0,0,12,0"
                    Background="Transparent"
                    Foreground="{DynamicResource ErrorBrush}"
                    BorderBrush="{DynamicResource ErrorBrush}"
                    BorderThickness="1" Cursor="Hand"
                    Click="Delete_Click"
                    Visibility="Collapsed"/>
            <Button Content="Cancel"
                    Padding="16,8" Margin="0,0,8,0"
                    Background="Transparent"
                    Foreground="{DynamicResource TextBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Cursor="Hand"
                    IsCancel="True"/>
            <Button Content="Save"
                    Padding="24,8"
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
