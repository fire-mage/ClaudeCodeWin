<Window x:Class="ClaudeCodeWin.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Claude Code for Windows (CCW)"
        Width="420" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">
    <StackPanel Margin="28,24,28,24">
        <TextBlock x:Name="TitleText"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryBrush}"/>

        <TextBlock Text="WPF GUI for Claude Code CLI"
                   Margin="0,4,0,0"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>

        <TextBlock x:Name="BuildText"
                   Margin="0,16,0,0" FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>

        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
            <TextBlock x:Name="EmailText"
                       VerticalAlignment="Center" FontSize="13"/>
            <Button x:Name="CopyEmailButton"
                    Content="Copy"
                    Margin="8,0,0,0" Padding="8,2,8,2"
                    FontSize="10" Cursor="Hand"
                    Background="Transparent"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Center"
                    Click="CopyEmail_Click"/>
        </StackPanel>

        <!-- Health Check -->
        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,16,0,0"/>

        <Button Content="Health Check..."
                Margin="0,16,0,0" Padding="16,6"
                HorizontalAlignment="Left"
                Background="Transparent"
                Foreground="{DynamicResource TextBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Cursor="Hand"
                ToolTip="Run system diagnostics: check CLI, authentication, Git, internet connectivity and more."
                Click="HealthCheck_Click"/>

        <Button Content="Close"
                Margin="0,16,0,0" Padding="32,8,32,8"
                Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Center"
                Click="Close_Click"/>
    </StackPanel>
</Window>
