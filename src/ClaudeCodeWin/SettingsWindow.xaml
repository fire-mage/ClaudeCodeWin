<Window x:Class="ClaudeCodeWin.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="480" Height="580"
        MinWidth="400" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="18" Height="18" VerticalAlignment="Top" Margin="0,2,8,0">
                                <Ellipse Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.5"
                                         Fill="Transparent"/>
                                <Ellipse x:Name="Dot" Width="10" Height="10"
                                         Fill="{StaticResource PrimaryBrush}" Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Top"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="18" Height="18" CornerRadius="3"
                                    BorderBrush="{StaticResource TextSecondaryBrush}"
                                    BorderThickness="1.5"
                                    Background="Transparent"
                                    VerticalAlignment="Top" Margin="0,2,8,0">
                                <TextBlock x:Name="Check" Text="&#x2713;" FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Top"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Update Channel -->
            <TextBlock Text="Update Channel" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>

            <RadioButton x:Name="StableRadio" GroupName="UpdateChannel"
                         Margin="0,0,0,6"
                         Checked="UpdateChannel_Changed">
                <StackPanel>
                    <TextBlock Text="Stable" FontWeight="SemiBold"/>
                    <TextBlock Text="Recommended. Receive only tested and verified updates."
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="BetaRadio" GroupName="UpdateChannel"
                         Margin="0,10,0,0"
                         Checked="UpdateChannel_Changed">
                <StackPanel>
                    <TextBlock Text="Beta" FontWeight="SemiBold"/>
                    <TextBlock Text="Get new features early. May contain bugs. For testers only."
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </RadioButton>

            <!-- Instructions section -->
            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,20,0,16"/>

            <TextBlock Text="Instructions" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

            <TextBlock x:Name="InstructionsSummary" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,8" TextWrapping="Wrap"/>

            <Button Content="Manage Instructions..."
                    Click="ManageInstructions_Click"
                    Padding="16,6"
                    HorizontalAlignment="Left"
                    Background="{StaticResource SurfaceLightBrush}"
                    Foreground="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="1"
                    Cursor="Hand"
                    ToolTip="View and edit Claude instruction files (global CLAUDE.md, project CLAUDE.md, CCW system instruction, memory)."/>

            <!-- Servers section -->
            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,20,0,16"/>

            <TextBlock Text="SSH &amp; Servers" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

            <TextBlock x:Name="ServersSummary" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,8" TextWrapping="Wrap"/>

            <Button Content="Manage Servers..."
                    Click="ManageServers_Click"
                    Padding="16,6"
                    HorizontalAlignment="Left"
                    Background="{StaticResource SurfaceLightBrush}"
                    Foreground="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="1"
                    Cursor="Hand"
                    ToolTip="Configure SSH key and known servers for deployment."/>

            <!-- Activation Code section -->
            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,20,0,16"/>

            <TextBlock Text="Activation Code" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

            <TextBlock x:Name="ActivationSummary" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,8" TextWrapping="Wrap"/>

            <Button Content="Manage Activation Code..."
                    Click="ManageActivationCode_Click"
                    Padding="16,6"
                    HorizontalAlignment="Left"
                    Background="{StaticResource SurfaceLightBrush}"
                    Foreground="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="1"
                    Cursor="Hand"
                    ToolTip="Enter an activation code to unlock extra features."/>

            <!-- API Keys section -->
            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,20,0,16"/>

            <TextBlock Text="API Keys" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

            <TextBlock x:Name="ApiKeysSummary" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,8" TextWrapping="Wrap"/>

            <Button Content="Manage API Keys..."
                    Click="ManageApiKeys_Click"
                    Padding="16,6"
                    HorizontalAlignment="Left"
                    Background="{StaticResource SurfaceLightBrush}"
                    Foreground="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="1"
                    Cursor="Hand"
                    ToolTip="Manage API keys for external services (Figma, etc.) with expiry tracking."/>

            <!-- Voice Input section -->
            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,20,0,16"/>

            <TextBlock Text="Voice Input" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

            <TextBlock x:Name="VoiceSummary" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,8" TextWrapping="Wrap"/>

            <CheckBox x:Name="VoiceEnabledCheck"
                      Style="{StaticResource SettingsCheckBox}"
                      Margin="0,0,0,8"
                      Checked="VoiceEnabled_Changed" Unchecked="VoiceEnabled_Changed">
                <StackPanel>
                    <TextBlock Text="Enable voice input" FontWeight="SemiBold"/>
                    <TextBlock Text="Adds a microphone button to the message composer. Uses OpenAI Whisper (offline, free)."
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </CheckBox>

            <StackPanel x:Name="VoiceModelPanel" Margin="26,0,0,0">
                <TextBlock Text="Model:" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox x:Name="VoiceModelCombo"
                          Width="300" HorizontalAlignment="Left"
                          Background="{StaticResource SurfaceLightBrush}"
                          Foreground="{StaticResource TextBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          SelectionChanged="VoiceModel_Changed"/>

                <StackPanel x:Name="VoiceDownloadPanel" Margin="0,8,0,0">
                    <Button x:Name="VoiceDownloadBtn" Content="Download Model"
                            Click="VoiceDownload_Click"
                            Padding="16,6"
                            HorizontalAlignment="Left"
                            Background="{StaticResource SurfaceLightBrush}"
                            Foreground="{StaticResource PrimaryBrush}"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="1"
                            Cursor="Hand"/>
                    <ProgressBar x:Name="VoiceDownloadProgress"
                                 Height="4" Margin="0,6,0,0"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 Background="{StaticResource SurfaceLightBrush}"
                                 Visibility="Collapsed"/>
                    <TextBlock x:Name="VoiceDownloadStatus" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button x:Name="VoiceDeleteBtn" Content="Delete Model"
                        Click="VoiceDelete_Click"
                        Padding="16,6" Margin="0,8,0,0"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        Foreground="{StaticResource ErrorBrush}"
                        BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        Visibility="Collapsed"/>
            </StackPanel>

            <!-- Vector Memory section -->
            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,20,0,16"/>

            <TextBlock Text="Vector Memory (Semantic Search)" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

            <TextBlock x:Name="VectorSummary" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,8" TextWrapping="Wrap"/>

            <CheckBox x:Name="VectorEnabledCheck"
                      Style="{StaticResource SettingsCheckBox}"
                      Margin="0,0,0,8"
                      Checked="VectorEnabled_Changed" Unchecked="VectorEnabled_Changed">
                <StackPanel>
                    <TextBlock Text="Enable semantic memory" FontWeight="SemiBold"/>
                    <TextBlock Text="Enriches Claude's context with semantically relevant knowledge from your chat history, KB articles, and notes. Uses a local ONNX model (~82 MB)."
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </CheckBox>

            <StackPanel x:Name="VectorModelPanel" Margin="26,0,0,0">
                <TextBlock x:Name="VectorModelStatus" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>

                <StackPanel x:Name="VectorDownloadPanel" Margin="0,4,0,0">
                    <Button x:Name="VectorDownloadBtn" Content="Download Model (82 MB)"
                            Click="VectorDownload_Click"
                            Padding="16,6"
                            HorizontalAlignment="Left"
                            Background="{StaticResource SurfaceLightBrush}"
                            Foreground="{StaticResource PrimaryBrush}"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="1"
                            Cursor="Hand"/>
                    <ProgressBar x:Name="VectorDownloadProgress"
                                 Height="4" Margin="0,6,0,0"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 Background="{StaticResource SurfaceLightBrush}"
                                 Visibility="Collapsed"/>
                    <TextBlock x:Name="VectorDownloadStatus" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button x:Name="VectorDeleteBtn" Content="Delete Model"
                        Click="VectorDelete_Click"
                        Padding="16,6" Margin="0,8,0,0"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        Foreground="{StaticResource ErrorBrush}"
                        BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        Visibility="Collapsed"/>

                <TextBlock x:Name="VectorIndexStats" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Close button -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
                <Button Content="Close" Style="{StaticResource PrimaryButton}" Click="Close_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
