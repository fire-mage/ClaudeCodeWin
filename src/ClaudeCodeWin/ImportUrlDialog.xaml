<Window x:Class="ClaudeCodeWin.ImportUrlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Plugin from URL"
        Width="520" Height="240"
        MinWidth="400" MinHeight="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Import Plugin" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12">
            Enter a URL to a markdown file containing skill material.
        </TextBlock>

        <TextBox Grid.Row="2" x:Name="UrlBox"
                 Background="{StaticResource SurfaceBrush}"
                 Foreground="{StaticResource TextBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 CaretBrush="{StaticResource TextBrush}"
                 Padding="8,6" FontSize="13" Margin="0,0,0,8"/>

        <TextBox Grid.Row="3" x:Name="NameBox"
                 Background="{StaticResource SurfaceBrush}"
                 Foreground="{StaticResource TextBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 CaretBrush="{StaticResource TextBrush}"
                 Padding="8,6" FontSize="13" Margin="0,0,0,4"
                 Tag="Plugin name (optional)"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Import" x:Name="ImportButton" Click="ImportButton_Click"
                    Style="{StaticResource PrimaryButton}"
                    Padding="24,6" Margin="0,0,8,0"/>
            <Button Content="Cancel" Click="CancelButton_Click"
                    Padding="24,6"
                    Background="{StaticResource SurfaceBrush}"
                    Foreground="{StaticResource TextBrush}"
                    BorderBrush="{StaticResource BorderBrush}"/>
        </StackPanel>
    </Grid>
</Window>
